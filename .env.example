# Runtime contour:
# - .env is base config
# - optional profile override file: .env.<ENV> (for example .env.dev / .env.prod)
ENV=dev
# Optional strict guard for dev/test safety:
# - when STRICT_ENV_GUARD=1 and ENV is dev/test, SOURCE_SHEET_NAME must differ from TARGET_SHEET_NAME
STRICT_ENV_GUARD=0

# Migration feature flags (all off by default)
MIGRATION_ENABLE_NEW_SYNC_PATH=0
MIGRATION_ENABLE_NEW_RENDER_PATH=0
MIGRATION_ENABLE_SOURCE_HASH_GATE=0
MIGRATION_DUAL_WRITE_STORE=0
MIGRATION_HASH_GATE_STATE_FILE=artifacts/tmp/source_hash_gate_state.json
MIGRATION_STORE_FILE=artifacts/tmp/normalized_store.json

# Google
GOOGLE_APPLICATION_CREDENTIALS=key/google_service_account.json
SOURCE_SHEET_NAME=Спонсорские ТНТ
TARGET_SHEET_NAME=Спонсорские ТНТ ТЕСТ
# Production-only target fallback (used when ENV=prod and TARGET_SHEET_NAME is empty)
TARGET_SHEET_NAME_PROD=

# Telegram
TG_TOKEN=__PUT_TOKEN_HERE__
DEFAULT_CHAT_ID=-1000000000000

# OpenAI
OPENAI_TOKEN=__PUT_TOKEN_HERE__
ORG_TOKEN=__PUT_ORG_HERE__

# Optional proxy
PROXY_URL=

# Yandex Object Storage (S3-compatible)
S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_BUCKET=dtm
AWS_ACCESS_KEY_ID=__PUT_KEY_HERE__
AWS_SECRET_ACCESS_KEY=__PUT_SECRET_HERE__

# Web/API domains
WEB_DOMAIN=solofarm.ru
API_DOMAIN_TEST=dtm-api-test.solofarm.ru
API_DOMAIN_PROD=dtm-api.solofarm.ru

# Store/read rollout policy
STORE_MODE=ydb_primary
READMODEL_SOURCE=ydb
NOTIFY_SOURCE=ydb
RENDER_SOURCE=ydb
DEBUG_API_EVENT_SHAPE=0
DEBUG_HTTP_EVENT=0
FRONTEND_API_DEFAULT_VERSION=v2

# YDB serverless
YDB_ID=
YDB_ENDPOINT=
YDB_DATABASE=

# Cloud function naming (test/prod split)
YC_CLOUD_FUNCTION_NAME=dtm-test
YC_CLOUD_FUNCTION_PROD_NAME=dtm
YC_CLOUD_FUNCTION_PROD_ID=

# API gateway/domain (test/prod split)
YC_API_GATEWAY_TEST_NAME=dtm-api-test
YC_API_GATEWAY_PROD_NAME=dtm-api-prod
YC_API_GATEWAY_TEST_ID=
YC_API_GATEWAY_PROD_ID=
YC_API_CERTIFICATE_ID_TEST=
YC_API_CERTIFICATE_ID_PROD=

# Agent notifications
TG_AGENT_TOKEN=__PUT_AGENT_BOT_TOKEN_HERE__
MY_CHAT_ID=__PUT_YOUR_CHAT_ID_HERE__
