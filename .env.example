# Secrets and per-install overrides only.
# Non-secret defaults (domains/sheets/runtime/deploy names) are in config/*.yaml.

# Telegram
TG_TOKEN=__PUT_TOKEN_HERE__
DEFAULT_CHAT_ID=__PUT_DEFAULT_CHAT_ID_HERE__
TG_AGENT_TOKEN=__PUT_AGENT_BOT_TOKEN_HERE__
MY_CHAT_ID=__PUT_YOUR_CHAT_ID_HERE__

# LLM
OPENAI_TOKEN=__PUT_TOKEN_HERE__
ORG_TOKEN=__PUT_ORG_HERE__
GOOGLE_LLM_API_KEY=__PUT_GOOGLE_KEY_HERE__
YANDEX_LLM_API_KEY=__PUT_YANDEX_KEY_HERE__

# Optional proxy
PROXY_URL=

# Object Storage credentials
AWS_ACCESS_KEY_ID=__PUT_KEY_HERE__
AWS_SECRET_ACCESS_KEY=__PUT_SECRET_HERE__

# YC auth (for deploy tooling)
YC_SA_JSON_CREDENTIALS=

# Optional tooling tokens
GITHUB_TOKEN=
JIRA_EMAIL=
JIRA_API_TOKEN=
